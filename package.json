{
  "name": "severino-obsidian",
  "private": true,
  "type": "module",
  "description": "Obsidian plugin suite for the Severino Labs vault: site-accurate writeup preview plus authoring power-ups, built on the site's own renderer.",
  "scripts": {
    "build": "node esbuild.config.mjs",
    "dev": "node esbuild.config.mjs --watch",
    "typecheck": "tsc --noEmit",
    "commands:emit": "node bin/emit-obsidian-commands.mjs",
    "commands:check": "node bin/emit-obsidian-commands.mjs --check",
    "describe": "node bin/severino-obsidian --describe",
    "describe:write": "node bin/severino-obsidian --write"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "esbuild": "^0.24.0",
    "markdown-it": "^14.1.0",
    "obsidian": "^1.7.2",
    "typescript": "^5.9.3"
  }
}
